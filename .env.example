# EazyClaw environment template.
# Set at least one provider API key and WEB_PASSWORD.

# Required for web dashboard auth.
WEB_PASSWORD=change-me

# LLM providers (set at least one).
KIMI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=

# Channels.
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
WHATSAPP_ENABLED=false
WHATSAPP_BRIDGE_URL=ws://whatsapp-bridge:3001
WHATSAPP_BRIDGE_TOKEN=

# Optional integrations.
GH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional web settings.
WEB_PORT=8080
